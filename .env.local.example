# ip³ PV-Tool — Umgebungsvariablen
# Kopiere diese Datei nach .env.local und trage die Supabase-Keys ein.
# (.env.local wird NICHT committet.)

# Supabase: Projekt-URL und anon/public Key
# Zu finden im Supabase-Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-Role-Key — NUR lokal für das Import-Skript (scripts/import-legacy.ts).
# NIEMALS committen oder im Browser/Client verwenden (umgeht RLS)!
SUPABASE_SERVICE_ROLE_KEY=

# Google-Kalender-Anbindung (read-only, je Mitarbeiter per OAuth) — optional.
# Google-Cloud-Projekt → OAuth-Client (Webanwendung) anlegen, Redirect-URI
# eintragen (z. B. https://DEINE-DOMAIN/api/google/oauth/callback) und Scope
# .../auth/calendar.readonly freigeben. Details in supabase/SETUP.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: vollständige Callback-URL überschreiben (sonst aus Request-Origin).
GOOGLE_OAUTH_REDIRECT=

# ChatGPT / OpenAI — intelligente Suche, Frage-Antwort-Assistent und
# KI-gestützte Datei-/Beleg-Zuordnung. Optional: ohne Key ist die KI aus,
# die App funktioniert wie bisher. Kostenpflichtig pro Anfrage (ein paar Cent).
# Hinweis (DSGVO): knappe Treffer-/Dokumentdaten werden an OpenAI übermittelt.
OPENAI_API_KEY=
# Optional: Standardmodell überschreiben (Default: gpt-4o-mini, günstig).
# Für deutlich bessere Tabellen-/Datenblatt-Auslese überall: OPENAI_MODEL=gpt-4o
OPENAI_MODEL=
# Optional: stärkeres Modell für die vollständige Datenblatt-Auslese
# („Datenblatt auslesen (KI)") — Default gpt-4o.
OPENAI_MODEL_STRONG=

# Web-Suche für „Technische Daten aus dem Netz ziehen" (Produkt-Anreicherung).
# Optional: ohne Key ist die Funktion aus. Provider: tavily (Default) oder brave.
#   Tavily: https://tavily.com  ·  Brave: https://brave.com/search/api
WEB_SEARCH_API_KEY=
WEB_SEARCH_PROVIDER=tavily

# Azure AI Document Intelligence — robuste PDF-/Scan-/Tabellen-Auslese (EU/DSGVO).
# Optional: ohne Keys nutzt die App die lokale pdf.js-Auslese (Fallback).
# Ressource in EU-Region anlegen (West Europe / Germany West Central).
#   Endpoint z. B. https://<name>.cognitiveservices.azure.com
AZURE_DOCINTEL_ENDPOINT=
AZURE_DOCINTEL_KEY=

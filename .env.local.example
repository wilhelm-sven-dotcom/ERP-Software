# ip³ PV-Tool — Umgebungsvariablen
# Kopiere diese Datei nach .env.local und trage die Supabase-Keys ein.
# (.env.local wird NICHT committet.)

# Supabase: Projekt-URL und anon/public Key
# Zu finden im Supabase-Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-Role-Key — NUR lokal für das Import-Skript (scripts/import-legacy.ts).
# NIEMALS committen oder im Browser/Client verwenden (umgeht RLS)!
SUPABASE_SERVICE_ROLE_KEY=

# Google-Kalender-Anbindung (read-only, je Mitarbeiter per OAuth) — optional.
# Google-Cloud-Projekt → OAuth-Client (Webanwendung) anlegen, Redirect-URI
# eintragen (z. B. https://DEINE-DOMAIN/api/google/oauth/callback) und Scope
# .../auth/calendar.readonly freigeben. Details in supabase/SETUP.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: vollständige Callback-URL überschreiben (sonst aus Request-Origin).
GOOGLE_OAUTH_REDIRECT=
